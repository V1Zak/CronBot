# ============================================
# CronBot Environment Variables
# Required by AI sub-agents to complete the Gauntlet Tests (see judge.md)
# Copy this file to .env and fill in your values
# ============================================

# --- AI Provider (Required for AI steps & Executive Summary - Test 3) ---
ANTHROPIC_API_KEY=

# --- Slack MCP Server ---
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# --- Notion MCP Server (Required for The Notion Audit - Test 2) ---
NOTION_API_KEY=

# --- Google Workspace / Gmail MCP Server (Required for Email Draft - Test 3) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_WORKSPACE_CREDENTIALS_PATH=

# --- Session-based Auth (for services using browser cookies) ---
SESSION_COOKIE=
AUTH_TOKEN=

# --- General ---
# Override default database path (optional)
# CRONBOT_DB_PATH=./cronbot.db
