# The Judge & Core Evaluator Credentials
# These keys are required by the AI sub-agents to complete the Gauntlet Tests defined in judge.md

# Required for AI Reasoning and Executive Summaries (Test 3)
ANTHROPIC_API_KEY=your_claude_api_key_here

# Required for The Notion Audit (Test 2)
NOTION_API_KEY=secret_your_notion_integration_key_here

# Required for the Google Workspace MCP (Test 3: Email Draft)
# Depending on the MCP implementation, you may need OAuth credentials or a Service Account
GOOGLE_WORKSPACE_CREDENTIALS_PATH=/path/to/your/credentials.json

# Optional: If any tests or bots are expanded to use Slack
SLACK_BOT_TOKEN=xoxb-your-slack-token
SLACK_APP_TOKEN=xapp-your-slack-app-token